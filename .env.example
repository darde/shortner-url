# ─── Backend (.env lives at backend/.env) ───────────────────────────────────

# Local development (Docker PostgreSQL via docker-compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/urlshortener

# Production (e.g. Neon serverless PostgreSQL — recommended for Vercel)
# DATABASE_URL=postgresql://<user>:<password>@<host>/<dbname>?sslmode=require
